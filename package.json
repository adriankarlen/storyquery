{
  "name": "storyquery",
  "version": "0.2.0",
  "description": "A CLI that queries Storybook design-system manifests and answers agent-friendly questions about components and documentation.",
  "keywords": [
    "storybook",
    "design-system",
    "cli",
    "manifest",
    "components",
    "agents"
  ],
  "license": "MIT",
  "author": "adriankarlen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adriankarlen/storyquery.git"
  },
  "type": "module",
  "bin": {
    "storyquery": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "arktype": "^2.2.0",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsdown": "^0.22.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
